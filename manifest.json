{
  "manifest_version": 3,
  "name": "Screenshot to Clipboard",
  "version": "1.1",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "bagroud.js"
  },
  "action": {
    "default_title": "Capture Screenshot"
  }
}